# Copy to .env and set your values.

# ===== Batch mode defaults (recommended) =====
BATCH_LIST_FILE="videos.list"
BATCH_OUTPUT_DIR="downloads"
BATCH_WORK_DIR="logs"
BATCH_RETRIES="2"
SKIP_EXISTING="yes"
CLEANUP_WORKDIR="yes"
REUSE_SEGMENTS="yes"

# If the same referer/origin/cookie is shared across many videos,
# set them once here and leave columns empty in videos.list.
DEFAULT_REFERER="https://otus.ru/learning/000000/"
DEFAULT_ORIGIN="https://otus.ru"
DEFAULT_COOKIE=""
DEFAULT_USER_AGENT="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36"

# ===== Legacy single-video workflow (optional) =====
REFERER="https://otus.ru/learning/000000/"
BASE_URL="https://m3.boomstream.com/.../some_lesson.mp4"
DOWNLOAD_WORKDIR="hls_download"
DOWNLOAD_OUTPUT="otus_video.mp4"

DECRYPT_PLAYLIST="chunklist.m3u8"
DECRYPT_KEY="key.bin"
DECRYPT_SEGMENTS_DIR="ts_files"
DECRYPT_OUTPUT="output_final.mp4"
